  preserveNumbers: 0
  farsi: 1
  originalText: "\u0627\u06AF\u0631 \u06A9\u0648\u062F\u06A9 \u062F\u0631 \u06AF\u0630\u0634\u062A\u0647
    \u0628\u0631\u0627\u06CC \u0627\u062E\u062A\u0644\u0627\u0644\u0627\u062A \u0631\u0648\u0627\u0646\u067E\u0632\u0634\u06A9\u06CC
    \u0645\u0635\u0631\u0641 \u062F\u0627\u0631\u0648  \u062F\u0627\u0634\u062A\u0647
    \u0648 \u062F\u0631 \u062D\u0627\u0644 \u062D\u0627\u0636\u0631 \u0645\u0635\u0631\u0641
    \u0646\u0645\u06CC\u06A9\u0646\u062F\u060C \u0645\u062F\u062A \u0632\u0645\u0627\u0646
    \u0645\u0635\u0631\u0641 \u062F\u0627\u0631\u0648\u060C \u0646\u0627\u0645 \u062F\u0627\u0631\u0648
    \u0648 \u0645\u062F\u062A \u0632\u0645\u0627\u0646\u06CC \u06A9\u0647 \u0627\u0632
