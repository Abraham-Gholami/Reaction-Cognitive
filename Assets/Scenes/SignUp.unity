  m_text: "\u0627\uFB94\uFEAE \uFB90\uFEEE\u062F\u06A9 \u062F\u0631 \uFB94\uFEAC\uFEB7\uFE98\uFEEA
    \uFE91\uFEAE\u0627\u06CC \u0627\uFEA7\uFE98\uFEFC\uFEFB\u062A \u0631\u0648\u0627\uFEE7\uFB59\uFEB0\uFEB7\uFB91\uFBFD
    \uFEE3\uFEBC\uFEAE\u0641 \u062F\u0627\u0631\u0648  \u062F\u0627\uFEB7\uFE98\uFEEA
    \u0648 \u062F\u0631 \uFEA3\uFE8E\u0644 \uFEA3\uFE8E\uFEBF\uFEAE \uFEE3\uFEBC\uFEAE\u0641
    \uFEE7\uFEE4\uFBFF\uFB91\uFEE8\uFEAA\u060C \uFEE3\uFEAA\u062A \u0632\uFEE3\uFE8E\u0646
    \uFEE3\uFEBC\uFEAE\u0641 \u062F\u0627\u0631\u0648\u060C \uFEE7\uFE8E\u0645 \u062F\u0627\u0631\u0648
    \u0648 \uFEE3\uFEAA\u062A \u0632\uFEE3\uFE8E\uFEE7\uFBFD \uFB90\uFEEA \u0627\u0632
    \uFEE3\uFEBC\uFEAE\u0641 \u062F\u0627\u0631\u0648 \uFE97\uFE8E \u0627\uFEFB\u0646
    \uFB94\uFEAC\uFEB7\uFE98\uFEEA \u0627\uFEB3\uFE96 \u0631\u0627 \u0648\u0627\u0631\u062F 
    \uFB90\uFEE8\uFBFF\uFEAA:"
  m_isRightToLeft: 1
