  originalText: "\u2022 <u> \u0627\u06CC\u0646 \u0628\u0631\u0646\u0627\u0645\u0647
    \u06CC\u06A9 \u0627\u0628\u0632\u0627\u0631 \u063A\u0631\u0628\u0627\u0644\u06AF\u0631\u06CC
    \u0627\u0648\u0644\u06CC\u0647 \u0627\u0633\u062A \u0648 \u062C\u0627\u06CC\u06AF\u0632\u06CC\u0646
    \u062A\u0634\u062E\u06CC\u0635 \u062A\u062E\u0635\u0635\u06CC \u067E\u0632\u0634\u06A9
    \u0648 \u0631\u0648\u0627\u0646\u0634\u0646\u0627\u0633 \u0646\u0645\u06CC\u200C\u0634\u0648\u062F.\n\u2022
    <u> \u0628\u0631\u0627\u06CC \u062F\u0631\u06CC\u0627\u0641\u062A \u0646\u062A\u06CC\u062C\u0647
    \u0645\u0639\u062A\u0628\u0631\u060C \u0622\u0632\u0645\u0648\u0646 \u0628\u0627\u06CC\u062F
    \u062F\u0631 \u0645\u062D\u06CC\u0637\u06CC \u0622\u0631\u0645 \u0648 \u0628\u062F\u0648\u0646
    \u062D\u0636\u0648\u0631 \u0639\u0648\u0627\u0645\u0644 \u0645\u0632\u0627\u062D\u0645
    \u0627\u0646\u062C\u0627\u0645 \u0634\u0648\u062F.\n\u2022 <u> \u062F\u0631 \u0637\u0648\u0644
    \u0628\u0627\u0632\u06CC\u060C \u062F\u0627\u062F\u0647\u200C\u0647\u0627\u06CC
    \u0633\u0646\u0633\u0648\u0631\u0647\u0627\u06CC \u062D\u0631\u06A9\u062A\u06CC
    \u06AF\u0648\u0634\u06CC (\u0634\u0627\u0645\u0644 \u0634\u062A\u0627\u0628\u200C\u0633\u0646\u062C
    \u0648 \u0698\u06CC\u0631\u0648\u0633\u06A9\u0648\u067E) \u0628\u0631\u0627\u06CC
    \u0627\u0631\u0632\u06CC\u0627\u0628\u06CC \u062F\u0642\u06CC\u0642\u200C\u062A\u0631
    \u062B\u0628\u062A \u0645\u06CC\u200C\u0634\u0648\u0646\u062F.\n\u2022 <u> \u062A\u0645\u0627\u0645
    \u0627\u0637\u0644\u0627\u0639\u0627\u062A \u062C\u0645\u0639\u200C\u0622\u0648\u0631\u06CC
    \u0634\u062F\u0647\u060C \u0645\u062D\u0631\u0645\u0627\u0646\u0647 \u0628\u0627\u0642\u06CC
    \u0645\u06CC\u200C\u0645\u0627\u0646\u062F \u0648 \u062A\u0646\u0647\u0627 \u0628\u0631\u0627\u06CC
    \u0627\u0631\u0627\u0626\u0647 \u063A\u0631\u0628\u0627\u0644\u06AF\u0631\u06CC
    \u0627\u0633\u062A\u0641\u0627\u062F\u0647 \u0645\u06CC\u200C\u0634\u0648\u062F.\n"
