    - target: {fileID: 8871449158286345252, guid: bd38996286c5db9448e02f5ad29e8e7f,
        type: 3}
      propertyPath: m_text
      value: "\u0622\uFBFE\uFE8E \u062F\u0631 \uFEE3\uFB91\uFE8E\u0646 \uFE91\uFEAE\uFB94\uFEB0\u0627\u0631\u06CC
        \u0622\u0632\uFEE3\uFEEE\u0646\u060C \uFEE3\uFEA4\uFEAE\u06A9 \uFEA3\uFEEE\u0627\u0633
        \uFB58\uFEAE\u062A \uFB90\uFEE8\uFEE8\uFEAA\u0647 \uFEE3\uFE9C\uFEDE \uFEBB\uFEAA\u0627\u06CC 
        \uFEE3\uFEB0\u0627\uFEA3\uFEE2\u060C \u0627\uFEB7\uFEA8\uFE8E\u0635 \u062F\uFBFE\uFB95\uFEAE
        \uFBFE\uFE8E \uFEEB\uFEAE \uFEE7\uFEEE\u0639 \uFEE3\uFEA4\uFEAE\uFB90\uFBFD
        \uFB90\uFEEA \uFEA3\uFEEE\u0627\u0633 \uFB90\uFEEE\u062F\u06A9 \u0631\u0627
        \u0627\u0632 \uFE91\uFE8E\u0632\u06CC  \uFB58\uFEAE\u062A \uFB90\uFEE8\uFEAA
        \u0648\uFE9F\uFEEE\u062F \u062F\u0627\u0631\u062F\u061F \u062F\u0631 \uFEBB\uFEEE\u0631\u062A
        \u0648\uFE9F\uFEEE\u062F \uFE91\uFEEA \uFEBB\uFEEE\u0631\u062A \uFEE3\uFEA8\uFE98\uFEBC\uFEAE
        \uFE97\uFEEE\uFEBF\uFBFF\uFEA2  \u062F\uFEEB\uFBFF\uFEAA."
      objectReference: {fileID: 0}
    - target: {fileID: 8871449158286345252, guid: bd38996286c5db9448e02f5ad29e8e7f,
