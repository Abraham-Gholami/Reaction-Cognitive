    - target: {fileID: 8871449158286345252, guid: bd38996286c5db9448e02f5ad29e8e7f,
        type: 3}
      propertyPath: originalText
      value: "\u0622\u06CC\u0627 \u062F\u0631 \u0645\u06A9\u0627\u0646 \u0628\u0631\u06AF\u0632\u0627\u0631\u06CC
